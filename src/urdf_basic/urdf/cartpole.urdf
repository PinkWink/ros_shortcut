<?xml version="1.0"?>
<robot name="cartpole">

  <link name="world"/>

  <material name="grey">
    <color rgba="0.5 0.5 0.5 1.0"/>
  </material>
  <material name="blue">
    <color rgba="0.2 0.2 0.8 1.0"/>
  </material>
  <material name="red">
    <color rgba="0.8 0.2 0.2 1.0"/>
  </material>

  <!-- rail: 2 m cylinder laid along the x axis, 1 m above the ground -->
  <link name="slide_bar">
    <visual>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.02" length="2.0"/>
      </geometry>
      <material name="grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.02" length="2.0"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 1.5708 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.3334" ixy="0" ixz="0" iyy="0.3334" iyz="0" izz="0.0002"/>
    </inertial>
  </link>

  <joint name="world_to_bar" type="fixed">
    <parent link="world"/>
    <child link="slide_bar"/>
    <origin xyz="0 0 1.0" rpy="0 0 0"/>
  </joint>

  <!-- cart: short vertical cylinder that slides along the rail -->
  <link name="cart">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.15"/>
      </geometry>
      <material name="blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.1" length="0.15"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.004375" ixy="0" ixz="0" iyy="0.004375" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="slider_joint" type="prismatic">
    <parent link="slide_bar"/>
    <child link="cart"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.9" upper="0.9" effort="100.0" velocity="10.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- pole: 0.5 m cylinder, starts 15 deg from vertical and falls freely -->
  <link name="pole">
    <visual>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.5"/>
      </geometry>
      <material name="red"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.5"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.25" rpy="0 0 0"/>
      <mass value="0.2"/>
      <inertia ixx="0.0041867" ixy="0" ixz="0" iyy="0.0041867" iyz="0" izz="0.00004"/>
    </inertial>
  </link>

  <joint name="pole_joint" type="continuous">
    <parent link="cart"/>
    <child link="pole"/>
    <origin xyz="0 0 0.075" rpy="0 0.2618 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.02" friction="0.005"/>
  </joint>

  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher">
      <topic>/joint_states</topic>
      <joint_name>slider_joint</joint_name>
      <joint_name>pole_joint</joint_name>
    </plugin>
  </gazebo>

</robot>
