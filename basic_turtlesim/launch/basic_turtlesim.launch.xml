<launch>
    <!-- turtlesim 시뮬레이터 -->
    <node pkg="turtlesim" exec="turtlesim_node" name="turtlesim"/>

    <!-- pose 구독 + cmd_vel 발행 노드 -->
    <node pkg="basic_turtlesim" exec="turtle_pose_cmd" name="turtle_pose_cmd" output="screen"/>

    <!-- set_pen 서비스 클라이언트 노드 -->
    <node pkg="basic_turtlesim" exec="turtle_service_client" name="turtle_service_client" output="screen"/>
</launch>
